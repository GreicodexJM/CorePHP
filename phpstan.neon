parameters:
    # ==========================================================================
    # CorePHP — PHPStan Configuration
    # Level 9: the strictest analysis level
    # ==========================================================================

    level: 9

    paths:
        - opt/corephp-vm/std/src

    # --------------------------------------------------------------------------
    # PHP version target
    # --------------------------------------------------------------------------
    phpVersion: 80500

    # --------------------------------------------------------------------------
    # Strict mode settings
    # --------------------------------------------------------------------------
    # Note: checkMissingIterableValueType, checkGenericClassInNonGenericObjectType,
    # and checkAlwaysTrueCheckTypeFunctionCall were removed in PHPStan 2.x
    # (they are now always enabled at level 9 by default).
    checkFunctionArgumentTypes:        true

    # --------------------------------------------------------------------------
    # Disallow mixed types — forces explicit typing everywhere
    # --------------------------------------------------------------------------
    reportUnmatchedIgnoredErrors:      false
    checkImplicitMixed:                true
    checkBenevolentUnionTypes:         true

    # --------------------------------------------------------------------------
    # Strict null checks
    # --------------------------------------------------------------------------
    treatPhpDocTypesAsCertain:         true

    # --------------------------------------------------------------------------
    # Parallelism — disabled so child workers don't hit php.ini disable_functions
    # --------------------------------------------------------------------------
    parallel:
        maximumNumberOfProcesses:      1

    # --------------------------------------------------------------------------
    # Ignored errors — runkit7 functions are not typed in PHPStan stubs
    # We suppress these specific false-positives from the FunctionOverrider
    # --------------------------------------------------------------------------
    ignoreErrors:
        # runkit7 functions are defined at runtime — suppress undefined function errors
        - message: '#Function runkit7_function_redefine not found#'
          path:    opt/corephp-vm/std/src/Engine/FunctionOverrider.php
        - message: '#Call to an undefined function runkit7_function_redefine#'
          path:    opt/corephp-vm/std/src/Engine/FunctionOverrider.php
        # curl_setopt CURLOPT_POSTFIELDS accepts raw string bodies (including empty) for valid HTTP semantics
        - message: '#curl_setopt expects non-empty-string\|null, string given#'
          path:    opt/corephp-vm/std/src/Net/Http/HttpClient.php

    # --------------------------------------------------------------------------
    # Bootstrap — autoloads the std library for analysis
    # --------------------------------------------------------------------------
    bootstrapFiles:
        - opt/corephp-vm/std/vendor/autoload.php

    # --------------------------------------------------------------------------
    # Excluded paths
    # --------------------------------------------------------------------------
    excludePaths:
        - opt/corephp-vm/std/vendor
        - opt/corephp-vm/std/tests
        - '*/vendor/*'

    # --------------------------------------------------------------------------
    # Custom type extensions (if added in future)
    # --------------------------------------------------------------------------
    # typeAliases:
    #   CollectionOf: 'core\Internal\Array\TypedCollection<mixed>'

includes:
    # PSL first-party PHPStan extension — provides precise types for all Psl\* functions
    - opt/corephp-vm/std/vendor/php-standard-library/phpstan-extension/extension.neon
    # Include PHPStan extension installer if available
    # - opt/corephp-vm/std/vendor/phpstan/extension-installer/loader.neon
